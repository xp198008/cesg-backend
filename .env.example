# CESG backend configuration example

# JT808 主动安全报警同步（1208）
# 自建平台（推荐）：8800 + 8003 登录
JT808_OPENAPI_BASE_URL=http://113.207.68.96:8800/api
JT808_OPENAPI_AUTH_MODE=8003
JT808_OPENAPI_ACCOUNT=admin
JT808_OPENAPI_PASSWORD=123456
JT808_OPENAPI_PASSWORD_HASHED=false
# 仅 gb35658 OpenAPI（1200 登录）需要 apitoken
JT808_OPENAPI_APITOKEN=
JT808_OPENAPI_TIMEOUT=15

JT808_ALARM_SYNC_ENABLED=true
JT808_ALARM_SYNC_INTERVAL_SECONDS=60
JT808_ALARM_SYNC_LOOKBACK_MINUTES=5
JT808_ALARM_SYNC_PAGE_SIZE=100
JT808_ALARM_SYNC_MAX_PAGES=20

# OBD speed violation check (reads {device}_OBD keys from Redis).
OBD_SPEED_CHECK_INTERVAL_SECONDS=30
OBD_REDIS_HOST=127.0.0.1
OBD_REDIS_PORT=6379
OBD_REDIS_PASSWORD=lgx123
# 与 JT808 redis.properties 的 database 保持一致（808 默认 1，不是 0）
OBD_REDIS_DB=1
OBD_REDIS_KEY_PATTERN=*_OBD
OBD_MIN_SPEED_KMH=10
OBD_STALE_SECONDS=300
OBD_POLYLINE_BUFFER_M=30

# Agent Worker AI（docs/AI.PDF）
AGENT_WORKER_BASE_URL=http://113.207.68.94:5002
AGENT_WORKER_API_KEY=
AGENT_WORKER_DEFAULT_COMPANY=三峰城服
AGENT_WORKER_TIMEOUT=60
AGENT_WORKER_VIDEO_TIMEOUT=300
