# CESG backend configuration example

# New JT808 OpenAPI alarm sync.
# Fill these values on the server, then set JT808_ALARM_SYNC_ENABLED=true.
JT808_OPENAPI_BASE_URL=https://www.gb35658.com/lingx3api
JT808_OPENAPI_ACCOUNT=
JT808_OPENAPI_PASSWORD=
JT808_OPENAPI_PASSWORD_HASHED=false
JT808_OPENAPI_APITOKEN=
JT808_OPENAPI_TIMEOUT=15

JT808_ALARM_SYNC_ENABLED=false
JT808_ALARM_SYNC_INTERVAL_SECONDS=60
JT808_ALARM_SYNC_LOOKBACK_MINUTES=5
JT808_ALARM_SYNC_PAGE_SIZE=100
JT808_ALARM_SYNC_MAX_PAGES=20
